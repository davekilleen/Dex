# ==============================================
# Dex Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# --- Core (required for all setups) ---

# LLM provider API key (Gemini, OpenAI, or Anthropic)
# GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# --- Office 365 Calendar (optional — alternative to Apple Calendar) ---
# Set calendar_backend: office365 in System/user-profile.yaml to enable.
# See: core/mcp/scripts/office365_get_refresh_token.py for the auth flow.

# MS_TENANT_ID=your_azure_tenant_id
# MS_CLIENT_ID=your_azure_app_client_id
# MS_CLIENT_SECRET=your_azure_app_client_secret
# MS_REFRESH_TOKEN=your_oauth_refresh_token
# MS_USER_EMAIL=user@example.com  # Only needed for app-only (non-delegated) flow

# --- Notion Sync (optional — syncs week priorities to Notion) ---

# NOTION_API_TOKEN=your_notion_integration_token
# NOTION_WEEK_DB_ID=your_notion_database_id

# --- Slack Bot (optional — conversational Dex via Slack DM) ---
# Create a Slack app at api.slack.com/apps with Socket Mode enabled.
# Required scopes: chat:write, im:read, im:write, im:history

# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_USER_ID=U0123456789
# NOTION_TRIAGE_DS_ID=your_notion_datasource_id  # For EOD check-in priorities

# --- Granola (auto-detected — no manual config needed) ---
# Granola stores credentials in its app data directory automatically.
