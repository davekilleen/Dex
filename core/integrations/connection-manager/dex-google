#!/usr/bin/env bash
#
# dex-google — token-injecting wrapper around gogcli (the `gog` CLI).
#
# Dex owns the Google OAuth runtime: we fetch a fresh access token from the
# connection-manager and hand it to gog via $GOG_ACCESS_TOKEN, so gog never
# manages its own Google auth. The token is passed through the environment,
# never on the command line or stdout. (gog reads --access-token from
# $GOG_ACCESS_TOKEN automatically — see `gog --help`.)
#
# Usage:  dex-google calendar events list --json
#         dex-google gmail search 'newer_than:7d' --json
#
set -euo pipefail

# Resolve the directory this script lives in (handles symlinks).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *)  SOURCE="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)/$TARGET" ;;
  esac
done
DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# gogcli must be installed; the wrapper only detects its absence.
if ! command -v gog >/dev/null 2>&1; then
  echo "gogcli not installed — run: brew install openclaw/tap/gogcli" >&2
  exit 1
fi

# Fetch a fresh access token. Capture rc without tripping `set -e`.
TOKEN="$(node "$DIR/get-token.cjs" google --access-token-only)" && rc=0 || rc=$?

case "$rc" in
  0)
    export GOG_ACCESS_TOKEN="$TOKEN"
    exec gog "$@"
    ;;
  2)
    echo "Google isn't connected. Run /connect google" >&2
    exit 2
    ;;
  3)
    echo "Google needs reconnecting. Run /connect google" >&2
    exit 3
    ;;
  *)
    echo "Token error" >&2
    exit 1
    ;;
esac
