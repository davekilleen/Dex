{
  "version": 1,
  "description": "Declarative ownership and bootstrap contract for Dex vault provisioning. More-specific rules take precedence over broader directory rules.",
  "minimal_shipped": [
    "System/.mcp.json.example",
    "core/paths.py",
    ".scripts/",
    "System/user-profile-template.yaml"
  ],
  "ownership": {
    "shipped": [
      ".agents/",
      ".claude/",
      ".cursor/",
      ".gitattributes",
      ".gitignore",
      ".obsidian/",
      ".scripts/",
      "06-Resources/Dex_System/",
      "CHANGELOG.md",
      "CLAUDE.md",
      "COMMERCIAL_LICENSE.md",
      "LICENSE",
      "README.md",
      "System/",
      "core/",
      "docs/",
      "env.example",
      "extensions/",
      "install.sh",
      "node_modules/",
      "package-lock.json",
      "package.json",
      "packages/",
      "requirements.txt",
      "staging/",
      "uv.lock"
    ],
    "mergeable-config": [
      ".mcp.json"
    ],
    "user-owned": [
      "00-Inbox/",
      "01-Quarter_Goals/",
      "02-Week_Priorities/",
      "03-Tasks/",
      "04-Projects/",
      "05-Areas/",
      "06-Resources/",
      "07-Archives/",
      "System/user-profile.yaml",
      "System/pillars.yaml",
      "CLAUDE.md#USER_EXTENSIONS",
      ".env",
      ".claude/skills/*-custom/",
      ".agents/skills/*-custom/"
    ],
    "generated": [
      "core/paths.json",
      "System/People_Index.json",
      "System/.dex/",
      ".venv/",
      "System/.onboarding-complete"
    ]
  },
  "para_directories": [
    "04-Projects",
    "05-Areas/People/Internal",
    "05-Areas/People/External",
    "00-Inbox/Meetings",
    "00-Inbox/Ideas",
    "06-Resources/Learnings",
    "06-Resources/Quarterly_Reviews",
    "07-Archives/04-Projects",
    "07-Archives/Plans",
    "07-Archives/Reviews",
    "System/Templates",
    "03-Tasks",
    "02-Week_Priorities"
  ],
  "seed_files": {
