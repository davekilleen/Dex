{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dex/contracts/portable-vault.schema.json",
  "title": "Dex Portable Vault Ownership Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "source",
    "vault_schema_supported",
    "ownership_classes",
    "mutation_policy",
    "hard_deny",
    "vault_regions",
    "rules",
    "capabilities"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "const": "core/portable_contract.py"
    },
    "vault_schema_supported": {
      "type": "string",
      "minLength": 1
    },
    "mutation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "brain",
        "vault",
        "seed",
        "generated",
        "runtime"
      ],
      "properties": {
        "brain": {
          "enum": [
            "replace",
            "write-if-absent",
            "regenerate",
            "never"
          ]
        },
        "vault": {
          "enum": [
            "replace",
            "write-if-absent",
            "regenerate",
            "never"
          ]
        },
        "seed": {
          "enum": [
            "replace",
            "write-if-absent",
            "regenerate",
            "never"
          ]
        },
        "generated": {
          "enum": [
            "replace",
            "write-if-absent",
            "regenerate",
            "never"
          ]
        },
        "runtime": {
          "enum": [
            "replace",
            "write-if-absent",
            "regenerate",
            "never"
          ]
        }
      }
    },
    "ownership_classes": {
      "type": "array",
      "items": {
        "enum": [
          "brain",
          "vault",
          "seed",
          "generated",
          "runtime"
        ]
      },
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "hard_deny": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "vault_regions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "kind",
          "ownership"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "file",
              "dir"
            ]
          },
          "ownership": {
            "enum": [
              "brain",
              "vault",
              "seed",
              "generated",
              "runtime"
            ]
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "default_enabled",
          "folders"
        ],
        "properties": {
          "default_enabled": {
            "type": "boolean"
          },
          "folders": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mcp": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "config": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
