BEGIN:VEVENT
UID:dex-daily-plan@magentic.com
DTSTART;TZID=Europe/London:20260406T093000
DTEND;TZID=Europe/London:20260406T100000
RRULE:FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR
SUMMARY:Dex /daily-plan
DESCRIPTION:Open Dex and run /daily-plan\nGenerates a context-aware plan from your calendar\, tasks\, and priorities.
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:Time for your daily plan — open Dex and run /daily-plan
TRIGGER:-PT5M
END:VALARM
END:VEVENT

